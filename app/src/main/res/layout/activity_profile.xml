<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".ui.home.ProfileActivity">

    <!-- ✅ Scroll content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ✅ Top white section with fish -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@color/white">

                <!-- Fish illustrations -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_fish_group"
                    android:alpha="0.8" />

                <!-- Profile image circle -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProfile"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="55dp"
                    app:cardElevation="4dp">
                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_jenny" />
                </androidx.cardview.widget.CardView>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="16dp"
                    android:text="JENNY KIM"
                    android:textColor="@color/normal_black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.1" />

            </FrameLayout>

            <!-- ✅ Edit & Share buttons -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="0dp"
                android:layout_marginTop="-16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <!-- Edit profile -->
                    <TextView
                        android:id="@+id/tvEditProfile"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Edit  profile"
                        android:textColor="@color/teal_700"
                        android:textSize="14sp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/gray_icon"
                        android:alpha="0.3" />

                    <!-- Share profile -->
                    <TextView
                        android:id="@+id/tvShareProfile"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Share  profile"
                        android:textColor="@color/teal_700"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ✅ Light blue bottom section -->
            <LinearLayout
                android:layout_width="430dp"
                android:layout_height="576dp"
                android:orientation="vertical"
                android:background="@color/light_blue"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="80dp"
                android:paddingBottom="80dp">

                <!-- EARNED BADGES -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEarnedBadges"
                    android:layout_width="303dp"
                    android:layout_height="89dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/teal_700"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Left teal border -->
                        <View
                            android:layout_width="6dp"
                            android:layout_height="match_parent"
                            android:background="@color/white"
                            android:alpha="0.4" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="EARNED BADGES"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="20dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- EVENT LOG -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEventLog"
                    android:layout_width="303dp"
                    android:layout_height="89dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/teal_700"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="match_parent"
                            android:background="@color/white"
                            android:alpha="0.4" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="EVENT LOG"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="20dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- REPORT HISTORY -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReportHistory"
                    android:layout_width="303dp"
                    android:layout_height="89dp"
                    android:layout_marginBottom="0dp"
                    app:cardBackgroundColor="@color/teal_700"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="match_parent"
                            android:background="@color/white"
                            android:alpha="0.4" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="REPORT HISTORY"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="20dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ✅ Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/teal_700"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/navCompass"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_compass"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_add"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/navLocation"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_area"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            app:tint="@color/white" />

    </LinearLayout>

</LinearLayout>