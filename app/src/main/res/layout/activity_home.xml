<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    tools:context=".ui.home.HomeActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/light_gray">


    <!-- Main scroll content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ✅ Top header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">
                <ImageView
                    android:id="@+id/imgHeader"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_home_background"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Logo circle -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_waralalogo" />
                </androidx.cardview.widget.CardView>

                <!-- WARALA text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="WARALA"
                    android:textColor="@color/bahama_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    app:layout_constraintBottom_toBottomOf="@id/cardLogo"
                    app:layout_constraintStart_toEndOf="@id/cardLogo"
                    app:layout_constraintTop_toTopOf="@id/cardLogo" />

                <!-- Menu icon -->
                <ImageView
                    android:id="@+id/imgMenu"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_menu"
                    app:tint="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Report Pollution button -->
                <Button
                    android:id="@+id/btnReportPollution"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/btn_teal_rounded"
                    android:fontFamily="serif"
                    android:paddingStart="10dp"
                    android:paddingEnd="16dp"
                    android:text="Report Pollution"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ✅ Location + Search section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select your location"
                    android:textColor="@color/light_brown"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Location dropdown -->
                <androidx.cardview.widget.CardView
                    android:layout_width="180dp"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="3dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/normal_black" />
                        <Spinner
                            android:id="@+id/spinnerLocation"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:paddingStart="8dp"
                            android:background="@null" />
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_narrow"
                            app:tint="@color/normal_black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Search bar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/light_brown" />
                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="search"
                            android:fontFamily="serif"
                            android:textColorHint="@color/light_brown"
                            android:textSize="14sp"
                            android:paddingStart="12dp" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_filter"
                            app:tint="@color/normal_black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Popular ocean clean-ups title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popular ocean clean-ups"
                    android:textColor="@color/normal_black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>

            <!-- ✅ Horizontal cleanup cards -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ✅ Card 1 — Clean a Shoreline -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardCleanup1"
                        android:layout_width="180dp"
                        android:layout_height="260dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/light_blue"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <!-- Image + heart -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="140dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_shoreline" />

                                <!-- White circle heart -->
                                <androidx.cardview.widget.CardView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="top|end"
                                    android:layout_margin="10dp"
                                    app:cardBackgroundColor="@color/white"
                                    app:cardCornerRadius="18dp"
                                    app:cardElevation="2dp">
                                    <ImageView
                                        android:id="@+id/imgHeart1"
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_heart"
                                        app:tint="@color/normal_black" />
                                </androidx.cardview.widget.CardView>

                            </FrameLayout>

                            <!-- Content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@color/light_blue"
                                android:padding="15dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CLEAN A SHORELINE"
                                    android:fontFamily="serif"
                                    android:textColor="@color/teal_700"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:layout_marginBottom="8dp">
                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:src="@drawable/ic_location"
                                        app:tint="@color/normal_black" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hikkaduwa, Sri Lanka"
                                        android:textColor="@color/white"
                                        android:fontFamily="serif"
                                        android:textSize="10sp"
                                        android:paddingStart="4dp" />
                                </LinearLayout>

                                <Button
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:background="@drawable/btn_teal_rounded"
                                    android:text="volunteer"
                                    android:textColor="@color/white"
                                    android:textSize="8dp"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp" />

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ✅ Card 2 — EFL Beach Cleanup -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardCleanup2"
                        android:layout_width="180dp"
                        android:layout_height="260dp"
                        app:cardBackgroundColor="@color/light_blue"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <!-- Image + heart -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="140dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/beach_cleanup" />

                                <!-- White circle heart -->
                                <androidx.cardview.widget.CardView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="top|end"
                                    android:layout_margin="10dp"
                                    app:cardBackgroundColor="@color/white"
                                    app:cardCornerRadius="18dp"
                                    app:cardElevation="2dp">
                                    <ImageView
                                        android:id="@+id/imgHeart2"
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_heart"
                                        app:tint="@color/normal_black" />
                                </androidx.cardview.widget.CardView>

                            </FrameLayout>

                            <!-- Content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@color/light_blue"
                                android:padding="15dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="EFL BEACH CLEANUP"
                                    android:fontFamily="serif"
                                    android:textColor="@color/teal_700"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:layout_marginBottom="8dp">
                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:src="@drawable/ic_location"
                                        app:tint="@color/normal_black" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Colombo, Sri Lanka"
                                        android:textColor="@color/white"
                                        android:fontFamily="serif"
                                        android:textSize="10sp"
                                        android:paddingStart="4dp" />
                                </LinearLayout>

                                <Button
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:background="@drawable/btn_teal_rounded"
                                    android:text="volunteer"
                                    android:textColor="@color/white"
                                    android:textSize="8dp"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp" />

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ✅ Events Happening section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Events Happening"
                    android:fontFamily="serif"
                    android:textColor="@color/normal_black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Event 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEvent1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/event_01_coral" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:text="SAVECORALS AWARNESS SESSION"
                                android:textColor="@color/teal_700"
                                android:fontFamily="serif"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <Button
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_teal_rounded"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Mark your calender"
                                android:textColor="@color/white"
                                android:textSize="8dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/imgHeartEvent1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_heart"
                            app:tint="@color/gray_icon" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Event 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEvent2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/event_02_cleanup" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:text="RELEASE TURTLES"
                                android:textColor="@color/teal_700"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <Button
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_teal_rounded"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Mark your calender"
                                android:textColor="@color/white"
                                android:textSize="8dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/imgHeartEvent2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_heart"
                            app:tint="@color/normal_black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ✅ Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            app:tint="@color/teal_700" />

        <ImageView
            android:id="@+id/navCompass"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_compass"
            app:tint="@color/teal_700" />

        <ImageView
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_add"
            app:tint="@color/teal_700" />

        <ImageView
            android:id="@+id/navLocation"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_area"
            app:tint="@color/teal_700" />

        <ImageView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            app:tint="@color/teal_700"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
    <!-- ✅ Right side drawer menu -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/teal_700"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/btnCloseDrawer"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <!-- ABOUT US -->
        <LinearLayout
            android:id="@+id/menuAboutUs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ABOUT US"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@color/white" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#80FFFFFF" />

        <!-- FAQ -->
        <LinearLayout
            android:id="@+id/menuFaq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FAQ"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@color/white" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#80FFFFFF" />

        <!-- CONTACT US -->
        <LinearLayout
            android:id="@+id/menuContactUs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CONTACT US"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@color/white" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#80FFFFFF" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>